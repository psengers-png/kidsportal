{
  "routes": [
    {
      "route": "/",
      "serve": "/home.html",
      "statusCode": 200
    },
    {
      "route": "/en",
      "serve": "/en/home.html",
      "statusCode": 200
    },
    {
      "route": "/en/",
      "serve": "/en/home.html",
      "statusCode": 200
    },
    {
      "route": "/cancelSubscription",
      "rewrite": "/api/cancelSubscription"
    },
    {
      "route": "/api/*",
      "serve": "/api/*",
      "allowedRoles": []
    }
  ]
}
